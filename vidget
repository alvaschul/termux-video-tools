#!/data/data/com.termux/files/usr/bin/env bash
# Simple wrapper for the Python tool.
TOOLS_DIR="${HOME}/termux-video-tools"
PY="${PREFIX:-/data/data/com.termux/files/usr}/bin/python3"
SCRIPT="$TOOLS_DIR/video_server.py"

if [ ! -f "$SCRIPT" ]; then
  echo "video_server.py not found in $TOOLS_DIR. Please place files there or adjust vidget."
  exit 1
fi

cmd="$1"
shift || true

case "$cmd" in
  serve)
    # usage: vidget serve [--port 8080]
    exec "$PY" "$SCRIPT" --serve "$@"
    ;;
  download)
    # usage: vidget download <url> [--format mp4] [--use-aria2] [--cookies /path/to/cookies.txt]
    exec "$PY" "$SCRIPT" --download "$@"
    ;;
  status)
    exec "$PY" "$SCRIPT" --status "$@"
    ;;
  migrate)
    # future: database migrations etc.
    echo "No migrations to run."
    ;;
  *)
    echo "Usage: vidget {serve|download|status} ..."
    echo "  vidget serve --port 8080"
    echo "  vidget download <URL> [--format best] [--use-aria2] [--cookies /path/to/cookies.txt]"
    echo "  vidget status <JOB_ID>"
    exit 1
    ;;
esac
